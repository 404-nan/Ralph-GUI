{
  "name": "ralph-loop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Temporary supervisor-based RalphLoop for Codex",
  "scripts": {
    "dev": "node --experimental-strip-types src/cli/dev.ts",
    "app:start": "node --experimental-strip-types src/cli/app.ts",
    "supervisor:start": "node --experimental-strip-types src/cli/supervisor.ts",
    "panel:start": "node --experimental-strip-types src/cli/panel.ts",
    "discord:start": "node --experimental-strip-types src/cli/discord.ts",
    "demo": "node --experimental-strip-types src/cli/demo.ts",
    "build": "node scripts/build.mjs",
    "lint": "node scripts/lint.mjs",
    "test": "node --experimental-strip-types --test --test-isolation=none"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
